# Bunsen environment — copy to `.env` and fill in real values.
#
#   cp .env.example .env
#
# `.env` is gitignored and is auto-loaded on `bn` startup because
# `bunsen.config.yaml` lists it under `defaults.envFiles`. Values already set in
# your shell take precedence over `.env` (the file never clobbers an explicit
# shell value). See README → "Environment Variables for Agents".

# --- Provider API keys ---------------------------------------------------------
# ANTHROPIC_API_KEY is required for orchestration and LLM evaluation, and is also
# passed into agent containers. The others are only needed for the matching agent
# (codex-cli → OpenAI, gemini-cli → Gemini). Leave unused keys blank.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# --- Optional ------------------------------------------------------------------
# Separate key for Bunsen's platform agents (orchestrator/scorer/supervisor). If
# unset, they fall back to ANTHROPIC_API_KEY.
# BUNSEN_ANTHROPIC_API_KEY=sk-ant-...

# Google's SDK also accepts GOOGLE_API_KEY as a fallback for the Gemini Direct API
# (and prefers it over GEMINI_API_KEY when both are set).
# GOOGLE_API_KEY=...
