{
  "name": "@bunsen-dev/sdk",
  "version": "0.2.0",
  "description": "Public TypeScript SDK for Bunsen",
  "author": "Matthew Job Granmoe",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bunsen-dev/bunsen.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://bunsen.dev",
  "bugs": "https://github.com/bunsen-dev/bunsen/issues",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "LICENSE",
    "LICENSING.md",
    "THIRD_PARTY.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "cp ../../LICENSE ../../LICENSING.md ../../THIRD_PARTY.md .",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bunsen-dev/types": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}
