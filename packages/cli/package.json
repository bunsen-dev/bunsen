{
  "name": "@bunsen-dev/cli",
  "version": "0.2.0",
  "description": "CLI for Bunsen — a general-purpose experiment runner for agentic systems",
  "author": "Matthew Job Granmoe",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "//": "private: the CLI is distributed as a standalone `bun build --compile` binary via GitHub Releases + install.sh / brew / scoop — NOT npm. Only @bunsen-dev/{sdk,types} publish to npm.",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bunsen-dev/bunsen.git",
    "directory": "packages/cli"
  },
  "homepage": "https://bunsen.dev",
  "bugs": "https://github.com/bunsen-dev/bunsen/issues",
  "bin": {
    "bn": "./dist/bin.js",
    "bunsen": "./dist/bin.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:binary": "node scripts/build-binary.mjs",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "bun test --isolate src",
    "test:watch": "bun test --isolate --watch src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@braintrust/lingua": "^0.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dockerode": "^4.0.0",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "tar": "^7.4.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@braintrust/lingua-wasm": "0.1.0",
    "@bunsen-dev/agents": "workspace:*",
    "@bunsen-dev/runtime": "workspace:*",
    "@bunsen-dev/types": "workspace:*",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.3.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.3.0"
  }
}
